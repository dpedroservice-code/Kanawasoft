            }
            window.clearNotifications = clearNotifications;

            async function markAsPurchased(productId) {
                try {
                    if (state.dbReady && state.isOnline) {
                        await updateData('produtos', productId, { estoque: 0 });
                    }
                    showToast('Item marcado como comprado!', 'success');
                    await loadShoppingList();
                    await loadMetrics();
                } catch (error) {
                    showToast('Erro ao marcar item', 'error');
                }
            }
            window.markAsPurchased = markAsPurchased;

            // ==================== CALCULADORA ====================
            let calcValue = '0';
            let calcPrev = '';
            let calcOp = null;
            let calcReset = false;

            function toggleCalculator() {
                DOM.calculator.classList.toggle('open');
            }
            window.toggleCalculator = toggleCalculator;

            function calcPress(value) {
                const display = DOM.calcDisplay;
                if (value === 'C') {
                    calcValue = '0'; calcPrev = ''; calcOp = null; calcReset = false;
                    display.textContent = '0'; return;
                }
                if (value === '=') {
                    if (calcOp && calcPrev) {
                        const result = calcCalculate(parseFloat(calcPrev), parseFloat(calcValue), calcOp);
                        display.textContent = result;
                        calcValue = result.toString(); calcPrev = ''; calcOp = null; calcReset = true;
                    }
                    return;
                }
                if (['+', '-', '×', '÷'].includes(value)) {
                    if (calcOp && calcPrev) {
                        const result = calcCalculate(parseFloat(calcPrev), parseFloat(calcValue), calcOp);
                        display.textContent = result;
                        calcPrev = result.toString();
                    } else {
                        calcPrev = calcValue;
                    }
                    calcOp = value; calcReset = true; return;
                }
                if (value === '±') { calcValue = (parseFloat(calcValue) * -1).toString(); display.textContent = calcValue; return; }
                if (value === '%') { calcValue = (parseFloat(calcValue) / 100).toString(); display.textContent = calcValue; return; }
                if (calcReset) { calcValue = '0'; calcReset = false; }
                if (value === '.' && calcValue.includes('.')) return;
                if (calcValue === '0' && value !== '.') { calcValue = value; } else { calcValue += value; }
                display.textContent = calcValue;
            }
            window.calcPress = calcPress;

            function calcCalculate(a, b, op) {
                switch (op) {
                    case '+': return a + b;
                    case '-': return a - b;
                    case '×': return a * b;
                    case '÷': return b !== 0 ? a / b : 'Erro';
                    default: return b;
                }
            }

            // ==================== MOBILE SIDEBAR ====================
            function toggleMobileSidebar() {
                document.getElementById('mobileSidebar').classList.toggle('open');
                document.getElementById('mobileOverlay').classList.toggle('open');
                document.body.style.overflow = document.getElementById('mobileSidebar').classList.contains('open') ? 'hidden' : '';
            }
            window.toggleMobileSidebar = toggleMobileSidebar;

            function closeMobileSidebar() {
                document.getElementById('mobileSidebar').classList.remove('open');
                document.getElementById('mobileOverlay').classList.remove('open');
                document.body.style.overflow = '';
            }
            window.closeMobileSidebar = closeMobileSidebar;

            // ==================== NOTIFICAÇÕES E USUÁRIO ====================
            function toggleNotifications() {
                document.getElementById('headerNotificationDropdown').classList.toggle('open');
            }
            window.toggleNotifications = toggleNotifications;

            function toggleUserMenu() {
                document.getElementById('headerUserDropdown').classList.toggle('open');
            }
            window.toggleUserMenu = toggleUserMenu;

            // ==================== EVENT LISTENERS ====================
            function setupEventListeners() {
                // Fechar dropdowns ao clicar fora
                document.addEventListener('click', function(e) {
                    if (!e.target.closest('#notificationBtn') && !e.target.closest('#headerNotificationDropdown')) {
                        document.getElementById('headerNotificationDropdown').classList.remove('open');
                    }
                    if (!e.target.closest('.header-user') && !e.target.closest('#headerUserDropdown')) {
                        document.getElementById('headerUserDropdown').classList.remove('open');
                    }
                });

                // Conexão
                window.addEventListener('online', function() {
                    state.isOnline = true;
                    updateConnectionStatus();
                    showToast('Conexão restaurada!', 'success');
                    syncData();
                });
                window.addEventListener('offline', function() {
                    state.isOnline = false;
                    updateConnectionStatus();
                    showToast('Modo offline ativado', 'warning');
                });

                // Conexão inicial
                checkConnection();

                // Verificar autenticação
                if (supabaseReady) {
                    supabase.auth.onAuthStateChange((event, session) => {
                        if (event === 'SIGNED_IN') {
                            console.log('👤 Usuário autenticado:', session?.user?.email);
                            if (!state.initialized) {
                                loadDashboard();
                            }
                        } else if (event === 'SIGNED_OUT') {
                            console.log('⚠️ Usuário desconectado');
                            localStorage.removeItem('user');
                            localStorage.removeItem('isLoggedIn');
                        }
                    });
                }

                // Se já estiver autenticado
                const userStr = localStorage.getItem('user');
                if (userStr && !state.initialized) {
                    loadDashboard();
                } else if (!state.initialized) {
                    // Verificar se há sessão ativa no Supabase
                    if (supabaseReady) {
                        supabase.auth.getSession().then(({ data }) => {
                            if (data.session) {
                                loadDashboard();
                            } else {
                                // Redirecionar para login se não houver sessão
                                window.location.href = 'Login.html';
                            }
                        });
                    } else {
                        // Fallback: carregar dashboard mesmo sem Supabase
                        loadDashboard();
                    }
                }
            }

            // ==================== INICIALIZAÇÃO ====================
            function init() {
                applySystemConfig();
                setupEventListeners();
                
                // Se já estiver autenticado, carregar dashboard
                if (localStorage.getItem('isLoggedIn') === 'true') {
                    loadDashboard();
                }
            }

            // ==================== EXPORTAÇÃO GLOBAL ====================
            window.SYSTEM_CONFIG = SYSTEM_CONFIG;
            window.toggleSubmenu = toggleSubmenu;
            window.openModule = openModule;
            window.showDashboard = showDashboard;
            window.syncData = syncData;
            window.showHelp = showHelp;
            window.toggleDarkMode = toggleDarkMode;
            window.logout = logout;
            window.openProfileModal = openProfileModal;
            window.closeProfileModal = closeProfileModal;
            window.saveProfile = saveProfile;
            window.markAsPurchased = markAsPurchased;
            window.markAsRead = markAsRead;
            window.markAllRead = markAllRead;
            window.clearNotifications = clearNotifications;
            window.toggleCalculator = toggleCalculator;
            window.calcPress = calcPress;
            window.toggleMobileSidebar = toggleMobileSidebar;
            window.closeMobileSidebar = closeMobileSidebar;
            window.toggleNotifications = toggleNotifications;
            window.toggleUserMenu = toggleUserMenu;
            window.showToast = showToast;

            // ==================== INICIAR ====================
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }

            // ==================== LIMPAR INTERVALOS ====================
            const intervals = window._intervals || [];
            intervals.forEach(id => clearInterval(id));
            window._intervals = [];

        })();
    </script>
