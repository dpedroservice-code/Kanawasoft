<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Kanawa Soft - Sistema de Gestão Completo</title>
    <link rel="shortcut icon" href="https://i.ibb.co/rf1prbJ0/KANAWASOFT.jpg" type="image/x-icon">
    <link rel="icon" type="image/jpg" href="https://i.ibb.co/rf1prbJ0/KANAWASOFT.jpg">
    <link rel="apple-touch-icon" href="https://i.ibb.co/rf1prbJ0/KANAWASOFT.jpg">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root {
            --header-height: 64px;
            --sidebar-width: 250px;
            --primary: #1e3a5f;
            --primary-light: #2a4a7a;
            --primary-dark: #0f2440;
            --secondary: #f59e0b;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --info: #3b82f6;
            --radius: 10px;
            --shadow: 0 2px 16px rgba(0,0,0,0.06);
            --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            --header-bg-start: #0f2440;
            --header-bg-end: #1e3a5f;
            --sidebar-bg-start: #0f2440;
            --sidebar-bg-end: #1e3a5f;
            --card-bg: #ffffff;
            --page-bg: #f0f4f9;
            --text-primary: #1e293b;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --border-color: #e2e8f0;
            --btn-primary: #3b82f6;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--page-bg);
            overflow: hidden;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 8px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        /* ==================== HEADER ==================== */
        .top-header {
            height: var(--header-height);
            background: linear-gradient(135deg, var(--header-bg-start) 0%, var(--header-bg-end) 100%);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            flex-shrink: 0;
            z-index: 1000;
            box-shadow: 0 2px 12px rgba(0,0,0,0.15);
        }
        .top-header .logo { display: flex; align-items: center; gap: 12px; text-decoration: none; color: #fff; }
        .top-header .logo img { height: 36px; width: auto; border-radius: 6px; flex-shrink: 0; }
        .top-header .logo-text { font-size: 1.1rem; font-weight: 700; letter-spacing: -0.5px; }
        .top-header .logo-text span { color: var(--secondary); }
        .top-header .header-right { display: flex; align-items: center; gap: 6px; }
        .top-header .header-btn {
            width: 38px; height: 38px; border-radius: 50%; border: none;
            background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.8);
            cursor: pointer; transition: var(--transition);
            display: flex; align-items: center; justify-content: center;
            position: relative; font-size: 1rem;
        }
        .top-header .header-btn:hover { background: rgba(255,255,255,0.16); color: #fff; }
        .top-header .header-btn .badge {
            position: absolute; top: 2px; right: 2px;
            background: var(--danger); color: #fff; font-size: 0.5rem;
            font-weight: 700; min-width: 18px; height: 18px;
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
        }
        .top-header .header-user {
            display: flex; align-items: center; gap: 10px;
            padding: 4px 12px 4px 4px; border-radius: 30px;
            cursor: pointer; transition: var(--transition);
            background: rgba(255,255,255,0.06); position: relative;
        }
        .top-header .header-user:hover { background: rgba(255,255,255,0.12); }
        .top-header .header-user .avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: var(--secondary); color: var(--primary-dark);
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: 0.8rem; flex-shrink: 0;
        }
        .top-header .header-user .name { font-weight: 500; font-size: 0.85rem; color: rgba(255,255,255,0.9); }
        .top-header .header-user .online-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--success); flex-shrink: 0; border: 1px solid var(--primary);
        }

        /* ==================== SIDEBAR ==================== */
        .main-wrapper { display: flex; flex: 1; overflow: hidden; }

        .sidebar {
            width: var(--sidebar-width);
            background: linear-gradient(180deg, var(--sidebar-bg-start) 0%, var(--sidebar-bg-end) 100%);
            color: #fff; flex-shrink: 0; overflow-y: auto; overflow-x: hidden;
            z-index: 100; transition: var(--transition); display: flex; flex-direction: column;
        }
        .sidebar::-webkit-scrollbar { width: 3px; }
        .sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 4px; }
        .sidebar .sidebar-user {
            padding: 16px 20px; display: flex; align-items: center; gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0;
        }
        .sidebar .sidebar-user .avatar {
            width: 40px; height: 40px; border-radius: 50%;
            background: var(--secondary); color: var(--primary-dark);
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: 1rem; flex-shrink: 0;
        }
        .sidebar .sidebar-user .user-info { flex: 1; min-width: 0; }
        .sidebar .sidebar-user .user-name { font-weight: 600; font-size: 0.9rem; }
        .sidebar .sidebar-user .user-role { font-size: 0.7rem; opacity: 0.6; }

        .sidebar .sidebar-nav { padding: 8px 12px 20px; flex: 1; overflow-y: auto; }
        .sidebar .sidebar-nav .menu-label {
            font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1px;
            opacity: 0.4; padding: 12px 8px 6px; font-weight: 600;
        }
        .sidebar .sidebar-nav .menu-item {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 14px; border-radius: 8px; cursor: pointer;
            transition: var(--transition); color: rgba(255,255,255,0.7);
            text-decoration: none; font-size: 0.85rem; border: none;
            background: transparent; width: 100%; text-align: left;
        }
        .sidebar .sidebar-nav .menu-item:hover { background: rgba(255,255,255,0.08); color: #fff; }
        .sidebar .sidebar-nav .menu-item.active { background: rgba(255,255,255,0.12); color: #fff; }
        .sidebar .sidebar-nav .menu-item i { width: 22px; text-align: center; font-size: 1rem; flex-shrink: 0; }
        .sidebar .sidebar-nav .menu-item .menu-arrow { margin-left: auto; font-size: 0.6rem; transition: var(--transition); opacity: 0.5; }
        .sidebar .sidebar-nav .menu-item .menu-arrow.open { transform: rotate(90deg); }
        .sidebar .sidebar-nav .submenu {
            overflow: hidden; max-height: 0;
            transition: max-height 0.3s ease, opacity 0.3s ease;
            opacity: 0; padding-left: 12px;
        }
        .sidebar .sidebar-nav .submenu.open { max-height: 500px; opacity: 1; }
        .sidebar .sidebar-nav .submenu .menu-item { padding: 8px 14px 8px 38px; font-size: 0.78rem; border-radius: 6px; }
        .sidebar .sidebar-nav .submenu .menu-item i { font-size: 0.85rem; width: 20px; }

        .sidebar .sidebar-footer {
            padding: 12px 20px; border-top: 1px solid rgba(255,255,255,0.06);
            text-align: center; flex-shrink: 0;
        }
        .sidebar .sidebar-footer .status { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 0.7rem; opacity: 0.6; }
        .sidebar .sidebar-footer .status .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--success); }
        .sidebar .sidebar-footer .version { font-size: 0.6rem; opacity: 0.4; margin-top: 4px; }

        /* ==================== MAIN CONTENT ==================== */
        .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .page-content { flex: 1; overflow-y: auto; padding: 20px 24px; background: var(--page-bg); }

        /* ==================== MOBILE ==================== */
        .mobile-menu-btn { display: none; background: none; border: none; color: #fff; font-size: 1.3rem; cursor: pointer; padding: 4px; }
        .mobile-sidebar {
            position: fixed; top: 0; left: 0; bottom: 0;
            width: 85%; max-width: 320px;
            background: linear-gradient(180deg, var(--sidebar-bg-start) 0%, var(--sidebar-bg-end) 100%);
            color: #fff; z-index: 9999; transform: translateX(-100%);
            transition: transform 0.3s ease; overflow-y: auto; display: none;
            box-shadow: 4px 0 30px rgba(0,0,0,0.2);
        }
        .mobile-sidebar.open { transform: translateX(0); }
        .mobile-sidebar .sidebar-header {
            padding: 16px 20px; display: flex; align-items: center;
            justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .mobile-sidebar .sidebar-header .logo { display: flex; align-items: center; gap: 10px; color: #fff; text-decoration: none; }
        .mobile-sidebar .sidebar-header .logo img { height: 32px; width: auto; border-radius: 6px; }
        .mobile-sidebar .sidebar-header .logo-text { font-size: 1rem; font-weight: 700; }
        .mobile-sidebar .sidebar-header .logo-text span { color: var(--secondary); }
        .mobile-sidebar .sidebar-header .close-btn { background: none; border: none; color: rgba(255,255,255,0.6); font-size: 1.3rem; cursor: pointer; }
        .mobile-sidebar .sidebar-user {
            padding: 16px 20px; display: flex; align-items: center; gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .mobile-sidebar .sidebar-user .avatar {
            width: 40px; height: 40px; border-radius: 50%;
            background: var(--secondary); color: var(--primary-dark);
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: 1rem; flex-shrink: 0;
        }
        .mobile-sidebar .sidebar-user .user-info { flex: 1; min-width: 0; }
        .mobile-sidebar .sidebar-user .user-name { font-weight: 600; font-size: 0.9rem; }
        .mobile-sidebar .sidebar-user .user-role { font-size: 0.7rem; opacity: 0.6; }
        .mobile-sidebar .sidebar-nav { padding: 8px 12px 20px; }
        .mobile-sidebar .sidebar-nav .menu-label {
            font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1px;
            opacity: 0.4; padding: 12px 8px 6px; font-weight: 600;
        }
        .mobile-sidebar .sidebar-nav .menu-item {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 14px; border-radius: 8px; cursor: pointer;
            transition: var(--transition); color: rgba(255,255,255,0.7);
            text-decoration: none; font-size: 0.85rem; border: none;
            background: transparent; width: 100%; text-align: left;
        }
        .mobile-sidebar .sidebar-nav .menu-item:hover { background: rgba(255,255,255,0.08); color: #fff; }
        .mobile-sidebar .sidebar-nav .menu-item.active { background: rgba(255,255,255,0.12); color: #fff; }
        .mobile-sidebar .sidebar-nav .menu-item i { width: 22px; text-align: center; font-size: 1rem; flex-shrink: 0; }
        .mobile-sidebar .sidebar-nav .menu-item .menu-arrow { margin-left: auto; font-size: 0.6rem; transition: var(--transition); opacity: 0.5; }
        .mobile-sidebar .sidebar-nav .menu-item .menu-arrow.open { transform: rotate(90deg); }
        .mobile-sidebar .sidebar-nav .submenu {
            overflow: hidden; max-height: 0;
            transition: max-height 0.3s ease, opacity 0.3s ease;
            opacity: 0; padding-left: 12px;
        }
        .mobile-sidebar .sidebar-nav .submenu.open { max-height: 500px; opacity: 1; }
        .mobile-sidebar .sidebar-nav .submenu .menu-item { padding: 8px 14px 8px 38px; font-size: 0.78rem; border-radius: 6px; }
        .mobile-sidebar .sidebar-nav .submenu .menu-item i { font-size: 0.85rem; width: 20px; }
        .mobile-sidebar .sidebar-footer {
            padding: 12px 20px; border-top: 1px solid rgba(255,255,255,0.06);
            text-align: center; flex-shrink: 0;
        }
        .mobile-sidebar .sidebar-footer .status { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 0.7rem; opacity: 0.6; }
        .mobile-sidebar .sidebar-footer .status .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--success); }
        .mobile-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.4);
            z-index: 9998; display: none;
        }
        .mobile-overlay.open { display: block; }

        /* ==================== CARDS ==================== */
        .card {
            background: var(--card-bg); border-radius: var(--radius);
            box-shadow: var(--shadow); border: 1px solid rgba(0,0,0,0.04);
            transition: var(--transition);
        }
        .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }

        .metric-card {
            padding: 18px 20px; display: flex; align-items: center;
            justify-content: space-between; background: var(--card-bg);
            border-radius: var(--radius); border: 1px solid rgba(0,0,0,0.04);
            box-shadow: var(--shadow);
        }
        .metric-card .info .label {
            font-size: 0.75rem; font-weight: 500; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.3px;
        }
        .metric-card .info .value {
            font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-top: 2px;
        }
        .metric-card .info .change { font-size: 0.7rem; font-weight: 500; margin-top: 2px; }
        .metric-card .icon {
            width: 46px; height: 46px; border-radius: var(--radius);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; flex-shrink: 0;
        }
        .metric-card .icon.blue { background: #dbeafe; color: #2563eb; }
        .metric-card .icon.green { background: #d1fae5; color: #059669; }
        .metric-card .icon.purple { background: #ede9fe; color: #7c3aed; }
        .metric-card .icon.yellow { background: #fef3c7; color: #d97706; }

        .quick-actions { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 10px; }
        .quick-action {
            background: var(--card-bg); border-radius: var(--radius);
            padding: 16px 12px; text-align: center; cursor: pointer;
            transition: var(--transition); border: 1px solid rgba(0,0,0,0.04);
            box-shadow: var(--shadow);
        }
        .quick-action:hover { transform: translateY(-3px); box-shadow: 0 6px 24px rgba(0,0,0,0.08); }
        .quick-action .icon {
            width: 40px; height: 40px; border-radius: var(--radius);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 8px; font-size: 1.1rem;
        }
        .quick-action .name { font-size: 0.75rem; font-weight: 500; color: var(--text-primary); }
        .quick-action .desc { font-size: 0.6rem; color: var(--text-muted); margin-top: 1px; }

        /* ==================== DROPDOWN ==================== */
        .dropdown {
            position: absolute; top: calc(100% + 6px); right: 0;
            background: #fff; border-radius: var(--radius);
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
            min-width: 260px; max-height: 400px; overflow: hidden;
            z-index: 9999; border: 1px solid rgba(0,0,0,0.06);
            display: none;
        }
        .dropdown.open { display: block; }
        .dropdown .dropdown-header {
            padding: 10px 16px; border-bottom: 1px solid #f1f5f9;
            display: flex; justify-content: space-between; align-items: center;
        }
        .dropdown .dropdown-header h4 { font-size: 0.85rem; font-weight: 600; color: #1e293b; }
        .dropdown .dropdown-header button { background: none; border: none; color: var(--info); font-size: 0.7rem; cursor: pointer; font-weight: 500; }
        .dropdown .dropdown-body { max-height: 280px; overflow-y: auto; }
        .dropdown .dropdown-item {
            padding: 10px 16px; display: flex; align-items: flex-start; gap: 10px;
            cursor: pointer; transition: var(--transition); border-bottom: 1px solid #f8fafc;
        }
        .dropdown .dropdown-item:hover { background: #f8fafc; }
        .dropdown .dropdown-item .item-icon {
            width: 30px; height: 30px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; font-size: 0.85rem;
        }
        .dropdown .dropdown-item .item-content { flex: 1; min-width: 0; }
        .dropdown .dropdown-item .item-title { font-size: 0.82rem; font-weight: 500; color: #1e293b; }
        .dropdown .dropdown-item .item-desc { font-size: 0.7rem; color: #94a3b8; margin-top: 1px; }
        .dropdown .dropdown-item .item-time { font-size: 0.6rem; color: #94a3b8; margin-top: 2px; }
        .dropdown .dropdown-footer { padding: 8px 16px; border-top: 1px solid #f1f5f9; text-align: center; }
        .dropdown .dropdown-footer button { background: none; border: none; color: #94a3b8; font-size: 0.75rem; cursor: pointer; }

        /* ==================== TOAST ==================== */
        .toast-container {
            position: fixed; top: 80px; right: 20px; z-index: 99999;
            display: flex; flex-direction: column; gap: 8px;
            max-width: 380px; width: 100%;
        }
        .toast {
            padding: 12px 16px; border-radius: var(--radius); color: #fff;
            box-shadow: 0 4px 20px rgba(0,0,0,0.12);
            animation: slideInRight 0.35s ease; display: flex; align-items: center; gap: 10px; font-size: 0.85rem;
        }
        .toast.success { background: var(--success); }
        .toast.error { background: var(--danger); }
        .toast.warning { background: var(--warning); }
        .toast.info { background: var(--info); }
        .toast .toast-close { margin-left: auto; background: none; border: none; color: #fff; opacity: 0.7; cursor: pointer; font-size: 1rem; }
        .toast .toast-close:hover { opacity: 1; }

        @keyframes slideInRight {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        /* ==================== LOADING ==================== */
        .loading-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.35);
            backdrop-filter: blur(3px); display: none;
            align-items: center; justify-content: center; z-index: 99999;
        }
        .loading-overlay.active { display: flex; }
        .loading-spinner {
            width: 40px; height: 40px;
            border: 3px solid rgba(255,255,255,0.2);
            border-top-color: #fff; border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ==================== CALCULATOR ==================== */
        .floating-calculator {
            position: fixed; bottom: 24px; right: 24px; z-index: 9999;
            background: var(--card-bg); border-radius: var(--radius);
            box-shadow: 0 8px 40px rgba(0,0,0,0.18);
            width: 260px; overflow: hidden; border: 1px solid rgba(0,0,0,0.06);
            display: none;
        }
        .floating-calculator.open { display: block; }
        .calc-header {
            padding: 10px 14px; background: #f8fafc;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid #e2e8f0;
        }
        .calc-header h4 { font-size: 0.8rem; font-weight: 600; color: #1e293b; }
        .calc-header button { background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 1rem; }
        .calc-display {
            padding: 14px 16px; background: #f8fafc; text-align: right;
            font-size: 1.6rem; font-weight: 700; color: #1e293b;
            min-height: 60px; border-bottom: 1px solid #e2e8f0;
            overflow: hidden; text-overflow: ellipsis;
        }
        .calc-buttons { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #e2e8f0; padding: 1px; }
        .calc-btn { padding: 14px; border: none; font-size: 0.9rem; cursor: pointer; font-weight: 500; background: #fff; color: #1e293b; }
        .calc-btn:hover { background: #f1f5f9; }
        .calc-btn.operator { background: #dbeafe; color: #2563eb; }
        .calc-btn.operator:hover { background: #bfdbfe; }
        .calc-btn.clear { background: #fee2e2; color: #dc2626; }
        .calc-btn.clear:hover { background: #fecaca; }
        .calc-btn.equals { background: #2563eb; color: #fff; }
        .calc-btn.equals:hover { background: #1d4ed8; }
        .calc-btn.span-2 { grid-column: span 2; }

        /* ==================== MODAL ==================== */
        .modal-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px); display: none;
            align-items: center; justify-content: center; z-index: 99999;
            padding: 20px;
        }
        .modal-overlay.active { display: flex; }
        .modal {
            background: var(--card-bg); border-radius: var(--radius);
            max-width: 520px; width: 100%; max-height: 90vh;
            overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        }
        .modal-header {
            padding: 14px 20px; border-bottom: 1px solid #f1f5f9;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; background: var(--card-bg); z-index: 1;
            border-radius: var(--radius) var(--radius) 0 0;
        }
        .modal-header h3 { font-size: 1rem; font-weight: 600; color: #1e293b; }
        .modal-header button { background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 1.2rem; padding: 4px; }
        .modal-body { padding: 20px; }
        .modal-footer {
            padding: 12px 20px; border-top: 1px solid #f1f5f9;
            display: flex; justify-content: flex-end; gap: 8px;
            position: sticky; bottom: 0; background: var(--card-bg);
            border-radius: 0 0 var(--radius) var(--radius);
        }
        .form-group { margin-bottom: 14px; }
        .form-group label { display: block; font-size: 0.78rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 3px; }
        .form-control {
            width: 100%; padding: 8px 12px; border: 1px solid var(--border-color);
            border-radius: 8px; font-size: 0.85rem; transition: var(--transition);
            background: var(--card-bg); color: var(--text-primary);
        }
        .form-control:focus { outline: none; border-color: var(--btn-primary); box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }

        /* ==================== CHARTS ==================== */
        .chart-container {
            background: var(--card-bg); border-radius: var(--radius);
