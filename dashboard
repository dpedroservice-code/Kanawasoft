            // ==================== DASHBOARD PRINCIPAL ====================
            async function loadDashboard() {
                if (state.initialized) return;
                state.initialized = true;
                
                if (DOM.dashboardContent) {
                    showLoading(true);
                    try {
                        await Promise.all([
                            loadUserData(),
                            loadCompanyData(),
                            loadProducts(),
                            loadClients(),
                            loadSales(),
                            loadNotifications(),
                            loadMetrics(),
                            loadShoppingList(),
                            loadActivities(),
                            loadEvents()
