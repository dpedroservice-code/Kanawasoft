            async function markAsRead(id) {
                try {
                    if (state.dbReady && state.isOnline) {
                        await updateData('notificacoes', id, { lida: true });
                    }
                    await loadNotifications();
                } catch (error) { console.error('Erro:', error); }
            }
            window.markAsRead = markAsRead;

            async function markAllRead() {
                try {
                    if (state.dbReady && state.isOnline) {
                        for (const n of state.notificacoes.filter(n => !n.lida)) {
                            await updateData('notificacoes', n.id, { lida: true });
                        }
                    }
                    await loadNotifications();
                    showToast('Todas as notificações marcadas como lidas', 'success');
                } catch (error) { console.error('Erro:', error); }
            }
            window.markAllRead = markAllRead;

            async function clearNotifications() {
                try {
                    if (state.dbReady && state.isOnline) {
                        for (const n of state.notificacoes) {
                            await updateData('notificacoes', n.id, { lida: true });
                        }
                    }
                    state.notificacoes = [];
                    renderNotifications();
                    showToast('Notificações limpas', 'info');
